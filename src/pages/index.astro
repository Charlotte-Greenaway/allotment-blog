---
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import Header from '../components/Header.astro';
import FormattedDate from '../components/FormattedDate.astro';
import { Image } from 'astro:assets';
import allotmentChar from '../assets/allotment-char.png';
import { SITE_DESCRIPTION, SITE_TITLE, BLOG_POSTS_PER_PAGE } from '../consts';
import { getCollection } from 'astro:content';

const posts = (await getCollection('blog')).sort(
	(a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf(),
);

const currentPage = 1;
const postsPerPage = BLOG_POSTS_PER_PAGE;
const totalPosts = posts.length;
const totalPages = Math.ceil(totalPosts / postsPerPage);
const start = (currentPage - 1) * postsPerPage;
const end = start + postsPerPage;
const paginatedPosts = posts.slice(start, end);
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} />
	</head>
	<body>
		<Header />
		<main>
			<div class="text-center heroSection">
				<Image src={allotmentChar} alt="A cartoon character with gardening equipment" class="indexImage" loading="eager" fetchpriority="high" decoding="async"/>
				<h1>Hey, I'm Charlotte! 👋</h1>
				<p>
					Welcome to my blog about gardening, growing food, and all things allotment-related. I started this blog to share my experiences and learnings as I cultivate my own little patch of green. 
				</p>
				<p>
					Whether you're a seasoned gardener or just starting out, I hope you'll find something here that inspires you to get your hands dirty and grow something wonderful. Happy gardening!
				</p>
			</div>
			<section>
				<ul>
					{
						paginatedPosts.map((post) => (
							<li>
								<a href={`/blog/${post.id}/`}>
									{post.data.heroImage && (
										<Image width={720} height={360} src={post.data.heroImage} alt={post.data.title} />
									)}
									<h2 class="title">{post.data.title}</h2> 
									<p class="date">
										<FormattedDate date={post.data.pubDate} />
									</p>
								</a>
							</li>
						))
					}
				</ul>
			</section>
			<nav class="pagination">
				{currentPage > 1 && (
					<a href={`/page/${currentPage - 1}`} class="prev">Previous</a>
				)}
				<span>Page {currentPage} of {totalPages}</span>
				{currentPage < totalPages && (
					<a href={`/page/${currentPage + 1}`} class="next">Next</a>
				)}
			</nav>
		</main>
		<Footer />
	</body>
</html>
