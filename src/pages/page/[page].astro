---
import BaseHead from '../../components/BaseHead.astro';
import Footer from '../../components/Footer.astro';
import Header from '../../components/Header.astro';
import FormattedDate from '../../components/FormattedDate.astro';
import { Image } from 'astro:assets';
import { SITE_DESCRIPTION, SITE_TITLE, BLOG_POSTS_PER_PAGE } from '../../consts';
import { getCollection } from 'astro:content';

const posts = (await getCollection('blog')).sort(
  (a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf()
);

const postsPerPage = BLOG_POSTS_PER_PAGE;
const totalPages = Math.ceil(posts.length / postsPerPage);

export async function getStaticPaths() {
  const posts = (await getCollection('blog')).sort(
    (a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf()
  );

  const postsPerPage = BLOG_POSTS_PER_PAGE;
  const totalPages = Math.ceil(posts.length / postsPerPage);

  return Array.from({ length: totalPages - 1 }, (_, i) => ({
    params: { page: (i + 2).toString() },
  }));
}

const currentPage = parseInt(Astro.params.page);

const start = (currentPage - 1) * postsPerPage;
const end = start + postsPerPage;
const paginatedPosts = posts.slice(start, end);
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} />
	</head>
	<body>
		<Header />
		<main>
			<section>
				<ul>
					{
						paginatedPosts.map((post) => (
							<li>
								<a href={`/blog/${post.id}/`}>
									{post.data.heroImage && (
										<Image width={720} height={360} src={post.data.heroImage} alt={post.data.title} />
									)}
									<h4 class="title">{post.data.title}</h4>
									<p class="date">
										<FormattedDate date={post.data.pubDate} />
									</p>
								</a>
							</li>
						))
					}
				</ul>
			</section>
			<nav class="pagination">
				{currentPage > 1 && (
					<a href={currentPage-1 == 1 ? `/` : `/page/${currentPage - 1}`} class="prev">Previous</a>
				)}
				<span>Page {currentPage} of {totalPages}</span>
				{currentPage < totalPages && (
					<a href={`/page/${currentPage + 1}`} class="next">Next</a>
				)}
			</nav>
		</main>
		<Footer />
	</body>
</html>
